{
  "name": "fumadocs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "CHOKIDAR_USEPOLLING=true npx -y node@22 ./node_modules/next/dist/bin/next dev --turbopack --port=4000",
    "start": "next start",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "meilisearch": "docker compose -f infra/meilisearch/docker-compose.yml up -d",
    "meilisearch:stop": "docker compose -f infra/meilisearch/docker-compose.yml down",
    "api:generate": "bun run scripts/generate-api-docs.ts",
    "api:index": "bun run scripts/index-api-meili.ts",
    "api:index:reset": "bun run scripts/index-api-meili.ts --reset"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@takumi-rs/image-response": "^0.69.5",
    "fumadocs-core": "16.6.8",
    "fumadocs-mdx": "14.2.9",
    "fumadocs-ui": "16.6.8",
    "lucide-react": "^0.575.0",
    "meilisearch": "^0.53.0",
    "next": "16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  }
}
