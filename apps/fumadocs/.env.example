# Meilisearch
MEILI_HOST=http://127.0.0.1:7700
MEILI_API_KEY=api-dev-master-key
MEILI_API_INDEX_NAME=api_entities
MEILI_ENABLE_HYBRID=false
MEILI_SEMANTIC_RATIO=0.35
MEILI_EMBEDDER_PROVIDER=openai
MEILI_EMBEDDER_MODEL=text-embedding-3-small

# App base URL used by tool executors
APP_BASE_URL=http://localhost:4000

# API reference dump source used at app startup (bun run start)
API_JSON_URL=https://cdn.sbox.game/releases/2026-03-05-14-31-39.zip.json
API_JSON_DOWNLOAD_TIMEOUT_MS=45000
API_JSON_DOWNLOAD_ATTEMPTS=3

# Optional: enable JSON line logging for API endpoints
API_LOGGING=false

# Optional: retrieval answer generation provider/model
# When using Chutes, set API_RAG_MODEL to a model id supported by your Chutes account.
API_RAG_PROVIDER=openai
API_RAG_MODEL=gpt-4.1-mini

# OpenAI provider settings
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1

# Chutes provider settings
CHUTES_API_KEY=
# Example: https://llm.chutes.ai/v1
CHUTES_API_BASE_URL=
