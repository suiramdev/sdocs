# Meilisearch
MEILI_HOST=http://127.0.0.1:7700
MEILI_API_KEY=api-dev-master-key
MEILI_API_INDEX_NAME=api_entities
MEILI_ENABLE_HYBRID=false
MEILI_SEMANTIC_RATIO=0.35

# App base URL used by tool executors
APP_BASE_URL=http://localhost:4000

# API reference dump source used at app startup (bun run start)
API_JSON_URL=https://cdn.sbox.game/releases/2026-03-05-14-31-39.zip.json

# Optional: enable JSON line logging for API endpoints
API_LOGGING=false

# Optional: retrieval answer generation model
OPENAI_API_KEY=
API_RAG_MODEL=gpt-4.1-mini
