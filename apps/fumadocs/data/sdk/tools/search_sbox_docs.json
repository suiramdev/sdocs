{
  "name": "search_sbox_docs",
  "description": "Search s&box SDK docs and return structured snippets including methods, descriptions, signatures, and example usage.",
  "input_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "query": {
        "type": "string",
        "description": "Natural-language query using class names, methods, components, or gameplay systems."
      },
      "limit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 25,
        "description": "Maximum number of results."
      },
      "type": {
        "type": "string",
        "enum": ["class", "method", "enum", "property"],
        "description": "Optional entity type filter."
      },
      "namespace": {
        "type": "string",
        "description": "Optional exact namespace filter."
      },
      "className": {
        "type": "string",
        "description": "Optional exact class filter."
      },
      "useHybrid": {
        "type": "boolean",
        "description": "Enable hybrid semantic+lexical ranking when available."
      }
    },
    "required": ["query"]
  },
  "execution": {
    "method": "POST",
    "path": "/api/sdk/tools/search-sbox-docs",
    "calls": "/api/sbox/search"
  }
}
